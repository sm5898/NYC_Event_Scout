# Required for Agent 1 (Preference Profiler) — get one at https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Optional overrides for Agent 1's Hugging Face call. Defaults match the
# provider/model already validated in notebooks/agent1_preference_profiler.ipynb.
HF_PROVIDER=publicai
HF_MODEL=swiss-ai/Apertus-70B-Instruct-2509
